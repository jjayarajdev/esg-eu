# ============================================================
# EU ESG Platform — Environment Configuration
# Copy to .env.local for local development
# ============================================================

# --- Core ---
NODE_ENV=development
PORT=3000

# --- Database ---
DATABASE_URL=postgresql://esg:esg_dev@localhost:5433/esg_platform

# --- Multi-Tenancy ---
TENANCY_MODE=shared  # 'shared' (SaaS: schema-per-tenant) or 'dedicated' (on-prem: single tenant)

# --- Auth ---
AUTH_PROVIDER=mock  # 'mock' (dev), 'auth0', 'clerk'
# AUTH0_DOMAIN=your-domain.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_AUDIENCE=https://api.your-domain.com

# --- Queue ---
QUEUE_PROVIDER=bullmq  # 'bullmq' (dev/on-prem), 'sqs' (AWS)
REDIS_URL=redis://localhost:6379

# --- Storage ---
STORAGE_PROVIDER=minio  # 'minio' (dev), 's3' (AWS), 'filesystem' (on-prem)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio_dev
STORAGE_BUCKET=esg-platform

# --- AI ---
AI_PROVIDER=mock  # 'mock' (dev), 'bedrock' (AWS), 'openai' (on-prem)
# AI_API_KEY=your-api-key
# AI_MODEL=claude-sonnet-4-6

# --- Connectors ---
USE_MOCK_CONNECTORS=true  # Use mock source services in development

# --- Frontend ---
VITE_API_URL=http://localhost:3000
VITE_AUTH_PROVIDER=mock
